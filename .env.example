# Stock Price Predictor - Environment Variables
# Copy this file to .env and customize the values

# ============================================
# Data Configuration
# ============================================

# Stock ticker symbol to analyze
TICKER=AAPL

# Date range for training data
START_DATE=2015-01-01
END_DATE=2025-12-31

# Number of days of history to use for each prediction
TIME_STEP=60

# Features to use for prediction (comma-separated)
FEATURES=Close,High,Low,Open,Volume,RSI,MA20,MA50,Sentiment

# Target feature to predict
TARGET_FEATURE=Close

# ============================================
# Model Architecture Configuration
# ============================================

# LSTM layer units
LSTM_UNITS=100

# Dropout rate for regularization (0.0 - 1.0)
DROPOUT_RATE=0.2

# Dense layer units before output
DENSE_UNITS=25

# Learning rate for optimizer
LEARNING_RATE=0.001

# ============================================
# File Paths
# ============================================

# Model and scaler file paths
MODEL_PATH=stock_predictor.keras
SCALER_X_PATH=scaler_x.joblib
SCALER_Y_PATH=scaler_y.joblib
SCALER_FEATURES_PATH=scaler_features.json

# ============================================
# Training Configuration
# ============================================

# Maximum number of training epochs
EPOCHS=100

# Batch size for training
BATCH_SIZE=64

# Validation split (0.0 - 1.0)
VALIDATION_SPLIT=0.2

# Early stopping patience (epochs without improvement)
EARLY_STOPPING_PATIENCE=10

# ============================================
# App Configuration
# ============================================

# Streamlit page settings
PAGE_TITLE=AI Stock Price Predictor
PAGE_ICON=📈
LAYOUT=wide

# Number of days to display in history chart
HISTORY_DAYS=90

# Extra days to fetch for indicator calculation
DATA_BUFFER_DAYS=100

# Sentiment analysis model
SENTIMENT_MODEL_NAME=ProsusAI/finbert
