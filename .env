# Stock Price Predictor - Environment Variables
# Active configuration (copy from .env.example and customize)

# ============================================
# Data Configuration
# ============================================

TICKER=AAPL
START_DATE=2015-01-01
END_DATE=2025-12-31
TIME_STEP=60
FEATURES=Close,High,Low,Open,Volume,RSI,MA20,MA50,Sentiment
TARGET_FEATURE=Close

# ============================================
# Model Architecture Configuration
# ============================================

LSTM_UNITS=100
DROPOUT_RATE=0.2
DENSE_UNITS=25
LEARNING_RATE=0.001

# ============================================
# File Paths
# ============================================

MODEL_PATH=stock_predictor.keras
SCALER_X_PATH=scaler_x.joblib
SCALER_Y_PATH=scaler_y.joblib
SCALER_FEATURES_PATH=scaler_features.json

# ============================================
# Training Configuration
# ============================================

EPOCHS=100
BATCH_SIZE=64
VALIDATION_SPLIT=0.2
EARLY_STOPPING_PATIENCE=10

# ============================================
# App Configuration
# ============================================

PAGE_TITLE=AI Stock Price Predictor
PAGE_ICON=📈
LAYOUT=wide
HISTORY_DAYS=90
DATA_BUFFER_DAYS=100
SENTIMENT_MODEL_NAME=ProsusAI/finbert
